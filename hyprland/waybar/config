{
    "layer": "top",
    "position": "top",
    "spacing": 4,
    "modules-left": [
        "hyprland/workspaces"
    ],
    "modules-center": [],
    "modules-right": [
        "temperature",
        "cpu",
        "memory",
        "network",
        "idle_inhibitor",
        "pulseaudio",
        "backlight",
        // "keyboard-state",
        "battery",
        "tray",
        "clock"
    ],
    "hyprland/workspaces": {
         "format": "{icon}",
         "on-click": "activate"
    },
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "ΎΑμ",
            "unlocked": "ΎΓε"
        }
    },
    "idle_inhibitor": {
        "format": " {icon} ",
        "format-icons": {
            "activated": "ΎΒχ",
            "deactivated": "ΎΒ░"
        }
    },
    "tray": {
        "spacing": 10
    },
    "clock": {
        "tooltip": true,
        "interval": 1,
        "format": "{:%a %b %d | %H:%M:%S}",
    },
    "cpu": {
        "format": "ΎΜδ  {usage}%"
    },
    "memory": {
        "format": "Ό┐Ζ  {}%"
    },
    "temperature": {
        "thermal-zone": 2,
        "hwmon-path": "/sys/class/hwmon/hwmon1/temp1_input",
        "format": "ΎΜΚ {temperatureC}┬░C",
    },
    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["ΌΟΞ", "ΌΠΥ", "ΌΠΣ", "ΌΠΠ", "ΌΠΟ", "ΌΠΞ", "ΌΠΛ", "ΌΠΙ", "ΌΟδ"]
    },
    "battery": {
        "states": {
            "warning": 40,
            "critical": 20
        },
        "format": "{icon} {capacity}%",
        "format-charging": "ΎΘο {capacity}%",
        "format-plugged": "ΎΘο {capacity}%",
        "format-alt": "{icon} {time}",
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
    },
    "network": {
        "interval": 1,
        "format-wifi": "ΎΘτ  ΎΒλ {bandwidthUpBytes} ΎΒμ {bandwidthDownBytes}",
        "format-ethernet": "≤░ΙΑ  ΎΒλ {bandwidthUpBytes} ΎΒμ {bandwidthDownBytes}",
        "format-disconnected": "≤░Νβ  No connection",
    },
    "pulseaudio": {
        "scroll-step": 5,
        "format": "{icon}  {volume}% {format_source}",
        "format-bluetooth": "ΎΛΦ {icon} {volume}% {format_source}",
        "format-bluetooth-muted": "ΎΛΦ {icon} {format_source}",
        "format-source": "ΎΕ░ {volume}%",
        "format-source-muted": "ΎΕ▒",
        "format-icons": {
            "default": ["ΎΑο", "ΎΑπ", "ΎΑπ", "ΎΑρ", "ΎΑρ"]
        },
        "on-click": "pavucontrol"
    }
}
